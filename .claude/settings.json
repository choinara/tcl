{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/post-edit-check.sh",
            "timeout": 30,
            "statusMessage": "코드 품질 검사 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/pre-commit-check.sh",
            "timeout": 30,
            "statusMessage": "커밋 전 검사 중..."
          }
        ]
      }
    ]
  }
}
